#: ../../../grammar.rst:3
msgid "Language Grammar"
msgstr ""

#: ../../../Solidity is a statically typed, contract-oriented, high-level
#: language for implementing smart contracts on the Ethereum platform.:3
msgid ""
"Solidity is a statically typed, contract-oriented, high-level language for "
"implementing smart contracts on the Ethereum platform."
msgstr ""

#: ../../../On top level, Solidity allows pragmas, import directives, and:10
msgid ""
"On top level, Solidity allows pragmas, import directives, and definitions of "
"contracts, interfaces, libraries, structs, enums and constants."
msgstr ""

