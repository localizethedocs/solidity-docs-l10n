#: ../../../internals/variable_cleanup.rst:57
msgid ""
"Note that valid and invalid values are dependent on their type size. "
"Consider ``uint8``, the unsigned 8-bit type, which has the following valid "
"values:"
msgstr ""

#: ../../../internals/variable_cleanup.rst:60
msgid ""
"0000...0000 0000 0000\n"
"0000...0000 0000 0001\n"
"0000...0000 0000 0010\n"
"....\n"
"0000...0000 1111 1111"
msgstr ""

#: ../../../internals/variable_cleanup.rst:68
msgid "Any invalid value will have the higher bits set to zero:"
msgstr ""

#: ../../../internals/variable_cleanup.rst:70
msgid ""
"0101...1101 0010 1010   invalid value\n"
"0000...0000 0010 1010   cleaned value"
msgstr ""

#: ../../../internals/variable_cleanup.rst:75
msgid "For ``int8``, the signed 8-bit type, the valid values are:"
msgstr ""

#: ../../../internals/variable_cleanup.rst:77
#: ../../../internals/variable_cleanup.rst:99
msgid "Negative"
msgstr ""

#: ../../../internals/variable_cleanup.rst:79
msgid ""
"1111...1111 1111 1111\n"
"1111...1111 1111 1110\n"
"....\n"
"1111...1111 1000 0000"
msgstr ""

#: ../../../internals/variable_cleanup.rst:86
#: ../../../internals/variable_cleanup.rst:106
msgid "Positive"
msgstr ""

#: ../../../internals/variable_cleanup.rst:88
msgid ""
"0000...0000 0000 0000\n"
"0000...0000 0000 0001\n"
"0000...0000 0000 0010\n"
"....\n"
"0000...0000 0111 1111"
msgstr ""

#: ../../../internals/variable_cleanup.rst:96
msgid ""
"The compiler will ``signextend`` the sign bit, which is 1 for negative and 0 "
"for positive values, overwriting the higher bits:"
msgstr ""

#: ../../../internals/variable_cleanup.rst:101
msgid ""
"0010...1010 1111 1111   invalid value\n"
"1111...1111 1111 1111   cleaned value"
msgstr ""

#: ../../../internals/variable_cleanup.rst:108
msgid ""
"1101...0101 0000 0100   invalid value\n"
"0000...0000 0000 0100   cleaned value"
msgstr ""
