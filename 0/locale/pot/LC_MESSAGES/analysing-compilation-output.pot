"        /* \"#utility.yul\":251:260   */\n"
"      dup3\n"
"        /* \"#utility.yul\":247:265   */\n"
"      add\n"
"        /* \"#utility.yul\":239:265   */\n"
"      swap1\n"
"      pop\n"
"        /* \"#utility.yul\":275:346   */\n"
"      tag_15\n"
"        /* \"#utility.yul\":343:344   */\n"
"      0x00\n"
"        /* \"#utility.yul\":332:341   */\n"
"      dup4\n"
"        /* \"#utility.yul\":328:345   */\n"
