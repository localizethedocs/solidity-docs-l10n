#: ../../../style-guide.rst:308
msgid "Order of Functions"
msgstr ""

#: ../../../style-guide.rst:310
msgid ""
"Ordering helps readers identify which functions they can call and to find "
"the constructor and fallback definitions easier."
msgstr ""

#: ../../../style-guide.rst:312
msgid "Functions should be grouped according to their visibility and ordered:"
msgstr ""

#: ../../../style-guide.rst:314
msgid "constructor"
msgstr ""

#: ../../../style-guide.rst:315
msgid "receive function (if exists)"
msgstr ""

#: ../../../style-guide.rst:316
msgid "fallback function (if exists)"
msgstr ""

#: ../../../style-guide.rst:317
msgid "external"
msgstr ""

#: ../../../style-guide.rst:318
msgid "public"
msgstr ""

#: ../../../style-guide.rst:319
msgid "internal"
msgstr ""

#: ../../../style-guide.rst:320
msgid "private"
msgstr ""

#: ../../../style-guide.rst:322
msgid "Within a grouping, place the ``view`` and ``pure`` functions last."
msgstr ""

#: ../../../style-guide.rst:326
msgid ""
"// SPDX-License-Identifier: GPL-3.0\n"
"pragma solidity >=0.7.0 <0.9.0;\n"
"contract A {\n"
"    constructor() {\n"
"        // ...\n"
"    }\n"
"\n"
"    receive() external payable {\n"
"        // ...\n"
"    }\n"
"\n"
"    fallback() external {\n"
"        // ...\n"
"    }\n"
"\n"
"    // External functions\n"
"    // ...\n"
"\n"
"    // External functions that are view\n"
"    // ...\n"
"\n"
"    // External functions that are pure\n"
"    // ...\n"
"\n"
"    // Public functions\n"
"    // ...\n"
"\n"
"    // Internal functions\n"
"    // ...\n"
"\n"
"    // Private functions\n"
"    // ...\n"
"}"
msgstr ""

#: ../../../style-guide.rst:364
msgid ""
"// SPDX-License-Identifier: GPL-3.0\n"
"pragma solidity >=0.7.0 <0.9.0;\n"
"contract A {\n"
"\n"
"    // External functions\n"
"    // ...\n"
"\n"
"    fallback() external {\n"
"        // ...\n"
"    }\n"
"    receive() external payable {\n"
"        // ...\n"
"    }\n"
"\n"
"    // Private functions\n"
"    // ...\n"
"\n"
"    // Public functions\n"
"    // ...\n"
"\n"
"    constructor() {\n"
"        // ...\n"
"    }\n"
"\n"
"    // Internal functions\n"
"    // ...\n"
"}"
msgstr ""

#: ../../../style-guide.rst:395
msgid "Whitespace in Expressions"
msgstr ""

#: ../../../style-guide.rst:397
msgid "Avoid extraneous whitespace in the following  situations:"
msgstr ""

#: ../../../style-guide.rst:399
msgid ""
"Immediately inside parenthesis, brackets or braces, with the exception of "
"single line function declarations."
msgstr ""

#: ../../../style-guide.rst:403
msgid "spam(ham[1], Coin({name: \"ham\"}));"
msgstr ""

#: ../../../style-guide.rst:409
msgid "spam( ham[ 1 ], Coin( { name: \"ham\" } ) );"
msgstr ""

#: ../../../style-guide.rst:413
msgid "Exception:"
msgstr ""

#: ../../../style-guide.rst:415
msgid "function singleLine() public { spam(); }"
msgstr ""

#: ../../../style-guide.rst:419
msgid "Immediately before a comma, semicolon:"
msgstr ""

#: ../../../style-guide.rst:423
msgid "function spam(uint i, Coin coin) public;"
msgstr ""

#: ../../../style-guide.rst:429
msgid "function spam(uint i , Coin coin) public ;"
msgstr ""

#: ../../../style-guide.rst:433
msgid ""
"More than one space around an assignment or other operator to align with "
"another:"
msgstr ""

#: ../../../style-guide.rst:437
msgid ""
"x = 1;\n"
"y = 2;\n"
"longVariable = 3;"
msgstr ""

#: ../../../style-guide.rst:445
msgid ""
"x            = 1;\n"
"y            = 2;\n"
"longVariable = 3;"
msgstr ""

#: ../../../style-guide.rst:451
msgid "Do not include a whitespace in the receive and fallback functions:"
msgstr ""

#: ../../../style-guide.rst:455
msgid ""
"receive() external payable {\n"
"    ...\n"
"}\n"
"\n"
"fallback() external {\n"
"    ...\n"
"}"
msgstr ""

#: ../../../style-guide.rst:467
msgid ""
"receive () external payable {\n"
"    ...\n"
"}\n"
"\n"
"fallback () external {\n"
"    ...\n"
"}"
msgstr ""

#: ../../../style-guide.rst:479
msgid "Control Structures"
msgstr ""

#: ../../../style-guide.rst:481
msgid ""
"The braces denoting the body of a contract, library, functions and structs "
"should:"
msgstr ""

#: ../../../style-guide.rst:484
msgid "open on the same line as the declaration"
msgstr ""

#: ../../../style-guide.rst:485
msgid ""
"close on their own line at the same indentation level as the beginning of "
"the declaration."
msgstr ""

#: ../../../style-guide.rst:487 ../../../style-guide.rst:615
msgid "The opening brace should be preceded by a single space."
msgstr ""

#: ../../../style-guide.rst:491
msgid ""
"// SPDX-License-Identifier: GPL-3.0\n"
"pragma solidity >=0.4.0 <0.9.0;\n"
"\n"
"contract Coin {\n"
"    struct Bank {\n"
"        address owner;\n"
"        uint balance;\n"
"    }\n"
"}"
msgstr ""

#: ../../../style-guide.rst:505
msgid ""
"// SPDX-License-Identifier: GPL-3.0\n"
"pragma solidity >=0.4.0 <0.9.0;\n"
"\n"
"contract Coin\n"
"{\n"
"    struct Bank {\n"
"        address owner;\n"
"        uint balance;\n"
"    }\n"
"}"
msgstr ""

#: ../../../style-guide.rst:518
msgid ""
"The same recommendations apply to the control structures ``if``, ``else``, "
"``while``, and ``for``."
msgstr ""

#: ../../../style-guide.rst:521
msgid ""
"Additionally there should be a single space between the control structures "
"``if``, ``while``, and ``for`` and the parenthetic block representing the "
"conditional, as well as a single space between the conditional parenthetic "
"block and the opening brace."
msgstr ""

#: ../../../style-guide.rst:528
msgid ""
"if (...) {\n"
"    ...\n"
"}\n"
"\n"
"for (...) {\n"
"    ...\n"
"}"
msgstr ""

#: ../../../style-guide.rst:540
msgid ""
"if (...)\n"
"{\n"
"    ...\n"
"}\n"
"\n"
"while(...){\n"
"}\n"
"\n"
"for (...) {\n"
"    ...;}"
msgstr ""

#: ../../../style-guide.rst:553
msgid ""
"For control structures whose body contains a single statement, omitting the "
"braces is ok *if* the statement is contained on a single line."
msgstr ""

#: ../../../style-guide.rst:558
msgid ""
"if (x < 10)\n"
"    x += 1;"
msgstr ""

#: ../../../style-guide.rst:565
msgid ""
"if (x < 10)\n"
"    someArray.push(Coin({\n"
"        name: 'spam',\n"
"        value: 42\n"
"    }));"
msgstr ""

#: ../../../style-guide.rst:573
msgid ""
"For ``if`` blocks which have an ``else`` or ``else if`` clause, the ``else`` "
"should be placed on the same line as the ``if``'s closing brace. This is an "
"exception compared to the rules of other block-like structures."
msgstr ""

#: ../../../style-guide.rst:579
msgid ""
"if (x < 3) {\n"
"    x += 1;\n"
"} else if (x > 7) {\n"
"    x -= 1;\n"
"} else {\n"
"    x = 5;\n"
"}\n"
"\n"
"\n"
"if (x < 3)\n"
"    x += 1;\n"
"else\n"
"    x -= 1;"
msgstr ""

#: ../../../style-guide.rst:597
msgid ""
"if (x < 3) {\n"
"    x += 1;\n"
"}\n"
"else {\n"
"    x -= 1;\n"
"}"
msgstr ""

#: ../../../style-guide.rst:607
msgid "Function Declaration"
msgstr ""

#: ../../../style-guide.rst:609
msgid ""
"For short function declarations, it is recommended for the opening brace of "
"the function body to be kept on the same line as the function declaration."
msgstr ""

#: ../../../style-guide.rst:612
msgid ""
"The closing brace should be at the same indentation level as the function "
"declaration."
msgstr ""

#: ../../../style-guide.rst:619
msgid ""
"function increment(uint x) public pure returns (uint) {\n"
"    return x + 1;\n"
"}\n"
"\n"
"function increment(uint x) public pure onlyOwner returns (uint) {\n"
"    return x + 1;\n"
"}"
msgstr ""

#: ../../../style-guide.rst:631
msgid ""
"function increment(uint x) public pure returns (uint)\n"
"{\n"
"    return x + 1;\n"
"}\n"
"\n"
"function increment(uint x) public pure returns (uint){\n"
"    return x + 1;\n"
"}\n"
"\n"
"function increment(uint x) public pure returns (uint) {\n"
"    return x + 1;\n"
"    }\n"
"\n"
"function increment(uint x) public pure returns (uint) {\n"
"    return x + 1;}"
msgstr ""

#: ../../../style-guide.rst:649
msgid "The modifier order for a function should be:"
