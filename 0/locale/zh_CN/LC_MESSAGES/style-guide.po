"}"
msgstr ""

#: ../../../style-guide.rst:787
msgid ""
"Multiline output parameters and return statements should follow the same "
"style recommended for wrapping long lines found in the :ref:`Maximum Line "
"Length <maximum_line_length>` section."
msgstr ""

#: ../../../style-guide.rst:791
msgid ""
"function thisFunctionNameIsReallyLong(\n"
"    address a,\n"
"    address b,\n"
"    address c\n"
")\n"
"    public\n"
"    returns (\n"
"        address someAddressName,\n"
"        uint256 LongArgument,\n"
"        uint256 Argument\n"
"    )\n"
"{\n"
"    doSomething()\n"
"\n"
"    return (\n"
"        veryLongReturnArg1,\n"
"        veryLongReturnArg2,\n"
"        veryLongReturnArg3\n"
"    );\n"
"}"
msgstr ""

#: ../../../style-guide.rst:816
msgid ""
"function thisFunctionNameIsReallyLong(\n"
"    address a,\n"
"    address b,\n"
"    address c\n"
")\n"
"    public\n"
"    returns (address someAddressName,\n"
"             uint256 LongArgument,\n"
"             uint256 Argument)\n"
"{\n"
"    doSomething()\n"
"\n"
"    return (veryLongReturnArg1,\n"
"            veryLongReturnArg1,\n"
"            veryLongReturnArg1);\n"
"}"
msgstr ""

#: ../../../style-guide.rst:835
msgid ""
"For constructor functions on inherited contracts whose bases require "
"arguments, it is recommended to drop the base constructors onto new lines in "
"the same manner as modifiers if the function declaration is long or hard to "
"read."
msgstr ""

#: ../../../style-guide.rst:841
msgid ""
"// SPDX-License-Identifier: GPL-3.0\n"
"pragma solidity >=0.7.0 <0.9.0;\n"
"// Base contracts just to make this compile\n"
"contract B {\n"
"    constructor(uint) {\n"
"    }\n"
"}\n"
"\n"
"\n"
"contract C {\n"
"    constructor(uint, uint) {\n"
"    }\n"
"}\n"
"\n"
"\n"
"contract D {\n"
"    constructor(uint) {\n"
"    }\n"
"}\n"
"\n"
"\n"
"contract A is B, C, D {\n"
"    uint x;\n"
"\n"
"    constructor(uint param1, uint param2, uint param3, uint param4, uint "
"param5)\n"
"        B(param1)\n"
"        C(param2, param3)\n"
"        D(param4)\n"
"    {\n"
"        // do something with param5\n"
"        x = param5;\n"
"    }\n"
"}"
msgstr ""

#: ../../../style-guide.rst:879
msgid ""
"// SPDX-License-Identifier: GPL-3.0\n"
"pragma solidity >=0.7.0 <0.9.0;\n"
"\n"
"// Base contracts just to make this compile\n"
"contract B {\n"
"    constructor(uint) {\n"
"    }\n"
"}\n"
"\n"
"\n"
"contract C {\n"
"    constructor(uint, uint) {\n"
"    }\n"
"}\n"
"\n"
"\n"
"contract D {\n"
"    constructor(uint) {\n"
"    }\n"
"}\n"
"\n"
"\n"
"contract A is B, C, D {\n"
"    uint x;\n"
"\n"
"    constructor(uint param1, uint param2, uint param3, uint param4, uint "
"param5)\n"
"    B(param1)\n"
"    C(param2, param3)\n"
"    D(param4) {\n"
"        x = param5;\n"
"    }\n"
"}\n"
"\n"
"\n"
"contract X is B, C, D {\n"
"    uint x;\n"
"\n"
"    constructor(uint param1, uint param2, uint param3, uint param4, uint "
"param5)\n"
"        B(param1)\n"
"        C(param2, param3)\n"
"        D(param4) {\n"
"            x = param5;\n"
"        }\n"
"}"
msgstr ""

#: ../../../style-guide.rst:927
msgid ""
"When declaring short functions with a single statement, it is permissible to "
"do it on a single line."
msgstr ""

#: ../../../style-guide.rst:929
msgid "Permissible:"
msgstr ""

#: ../../../style-guide.rst:931
msgid "function shortFunction() public { doSomething(); }"
msgstr ""

#: ../../../style-guide.rst:935
msgid ""
"These guidelines for function declarations are intended to improve "
"readability. Authors should use their best judgment as this guide does not "
"try to cover all possible permutations for function declarations."
msgstr ""

#: ../../../style-guide.rst:940
msgid "Mappings"
msgstr ""

#: ../../../style-guide.rst:942
msgid ""
"In variable declarations, do not separate the keyword ``mapping`` from its "
"type by a space. Do not separate any nested ``mapping`` keyword from its "
"type by whitespace."
msgstr ""

#: ../../../style-guide.rst:948
msgid ""
"mapping(uint => uint) map;\n"
"mapping(address => bool) registeredAddresses;\n"
"mapping(uint => mapping(bool => Data[])) public data;\n"
"mapping(uint => mapping(uint => s)) data;"
msgstr ""

#: ../../../style-guide.rst:957
msgid ""
"mapping (uint => uint) map;\n"
"mapping( address => bool ) registeredAddresses;\n"
"mapping (uint => mapping (bool => Data[])) public data;\n"
"mapping(uint => mapping (uint => s)) data;"
msgstr ""

#: ../../../style-guide.rst:965
msgid "Variable Declarations"
msgstr ""

#: ../../../style-guide.rst:967
msgid ""
"Declarations of array variables should not have a space between the type and "
"the brackets."
msgstr ""

#: ../../../style-guide.rst:972
msgid "uint[] x;"
msgstr ""

#: ../../../style-guide.rst:978
msgid "uint [] x;"
msgstr ""

#: ../../../style-guide.rst:984
msgid "Other Recommendations"
msgstr ""

#: ../../../style-guide.rst:986
msgid "Strings should be quoted with double-quotes instead of single-quotes."
msgstr ""

#: ../../../style-guide.rst:990
msgid ""
"str = \"foo\";\n"
"str = \"Hamlet says, 'To be or not to be...'\";"
msgstr ""

#: ../../../style-guide.rst:997
msgid ""
"str = 'bar';\n"
"str = '\"Be yourself; everyone else is already taken.\" -Oscar Wilde';"
msgstr ""

#: ../../../style-guide.rst:1002
msgid "Surround operators with a single space on either side."
msgstr ""

#: ../../../style-guide.rst:1006
msgid ""
"x = 3;\n"
"x = 100 / 10;\n"
"x += 3 + 4;\n"
"x |= y && z;"
msgstr ""

#: ../../../style-guide.rst:1016
msgid ""
"x=3;\n"
"x = 100/10;\n"
"x += 3+4;\n"
"x |= y&&z;"
msgstr ""

#: ../../../style-guide.rst:1024
msgid ""
"Operators with a higher priority than others can exclude surrounding "
"whitespace in order to denote precedence.  This is meant to allow for "
"improved readability for complex statements. You should always use the same "
"amount of whitespace on either side of an operator:"
msgstr ""

#: ../../../style-guide.rst:1031
msgid ""
"x = 2**3 + 5;\n"
"x = 2*y + 3*z;\n"
"x = (a+b) * (a-b);"
msgstr ""

#: ../../../style-guide.rst:1039
msgid ""
"x = 2** 3 + 5;\n"
"x = y+z;\n"
"x +=1;"
msgstr ""

