msgid "Events"
msgstr ""

#: ../../../style-guide.rst:1054 ../../../style-guide.rst:1064
msgid "Errors"
msgstr ""

#: ../../../style-guide.rst:1055
msgid "Interfaces"
msgstr ""

#: ../../../style-guide.rst:1056
msgid "Libraries"
msgstr ""

#: ../../../style-guide.rst:1057
msgid "Contracts"
msgstr ""

#: ../../../style-guide.rst:1059
msgid "Inside each contract, library or interface, use the following order:"
msgstr ""

#: ../../../style-guide.rst:1061
msgid "Type declarations"
msgstr ""

#: ../../../style-guide.rst:1062
msgid "State variables"
msgstr ""

#: ../../../style-guide.rst:1065
msgid "Modifiers"
msgstr ""

#: ../../../style-guide.rst:1066
