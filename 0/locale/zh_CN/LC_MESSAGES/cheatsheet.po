#: ../../../cheatsheet.rst:15
msgid "ABI Encoding and Decoding Functions"
msgstr ""

#: ../../../cheatsheet.rst:17
msgid ""
"``abi.decode(bytes memory encodedData, (...)) returns (...)``: :ref:`ABI "
"<ABI>`-decodes the provided data. The types are given in parentheses as "
"second argument. Example: ``(uint a, uint[2] memory b, bytes memory c) = abi."
"decode(data, (uint, uint[2], bytes))``"
msgstr ""

#: ../../../cheatsheet.rst:20
msgid ""
"``abi.encode(...) returns (bytes memory)``: :ref:`ABI <ABI>`-encodes the "
"given arguments"
msgstr ""

#: ../../../cheatsheet.rst:21
msgid ""
"``abi.encodePacked(...) returns (bytes memory)``: Performs :ref:`packed "
"encoding <abi_packed_mode>` of the given arguments. Note that this encoding "
"can be ambiguous!"
msgstr ""

#: ../../../cheatsheet.rst:23
msgid ""
"``abi.encodeWithSelector(bytes4 selector, ...) returns (bytes memory)``: :"
"ref:`ABI <ABI>`-encodes the given arguments starting from the second and "
"prepends the given four-byte selector"
msgstr ""

#: ../../../cheatsheet.rst:25
msgid ""
"``abi.encodeCall(function functionPointer, (...)) returns (bytes memory)``: "
"ABI-encodes a call to ``functionPointer`` with the arguments found in the "
"tuple. Performs a full type-check, ensuring the types match the function "
"signature. Result equals ``abi.encodeWithSelector(functionPointer."
"selector, ...)``"
msgstr ""

#: ../../../cheatsheet.rst:27
msgid ""
"``abi.encodeWithSignature(string memory signature, ...) returns (bytes "
"memory)``: Equivalent to ``abi."
"encodeWithSelector(bytes4(keccak256(bytes(signature))), ...)``"
msgstr ""

#: ../../../cheatsheet.rst:33
msgid "Members of ``bytes`` and  ``string``"
msgstr ""

#: ../../../cheatsheet.rst:35
msgid ""
"``bytes.concat(...) returns (bytes memory)``: :ref:`Concatenates variable "
"number of arguments to one byte array<bytes-concat>`"
msgstr ""

#: ../../../cheatsheet.rst:38
msgid ""
"``string.concat(...) returns (string memory)``: :ref:`Concatenates variable "
"number of arguments to one string array<string-concat>`"
msgstr ""

#: ../../../cheatsheet.rst:44
msgid "Members of ``address``"
msgstr ""

#: ../../../cheatsheet.rst:46
msgid ""
"``<address>.balance`` (``uint256``): balance of the :ref:`address` in Wei"
msgstr ""

#: ../../../cheatsheet.rst:47
msgid ""
"``<address>.code`` (``bytes memory``): code at the :ref:`address` (can be "
"empty)"
msgstr ""

#: ../../../cheatsheet.rst:48
msgid ""
"``<address>.codehash`` (``bytes32``): the codehash of the :ref:`address`"
msgstr ""

#: ../../../cheatsheet.rst:49
msgid ""
"``<address>.call(bytes memory) returns (bool, bytes memory)``: issue low-"
"level ``CALL`` with the given payload, returns success condition and return "
"data"
msgstr ""

#: ../../../cheatsheet.rst:51
msgid ""
"``<address>.delegatecall(bytes memory) returns (bool, bytes memory)``: issue "
"low-level ``DELEGATECALL`` with the given payload, returns success condition "
"and return data"
msgstr ""

#: ../../../cheatsheet.rst:53
msgid ""
"``<address>.staticcall(bytes memory) returns (bool, bytes memory)``: issue "
"low-level ``STATICCALL`` with the given payload, returns success condition "
"and return data"
msgstr ""

#: ../../../cheatsheet.rst:55
msgid ""
"``<address payable>.send(uint256 amount) returns (bool)``: send given amount "
"of Wei to :ref:`address`, returns ``false`` on failure (deprecated)"
msgstr ""

#: ../../../cheatsheet.rst:57
msgid ""
"``<address payable>.transfer(uint256 amount)``: send given amount of Wei to :"
"ref:`address`, throws on failure (deprecated)"
msgstr ""

#: ../../../cheatsheet.rst:63
msgid "Block and Transaction Properties"
msgstr ""

#: ../../../cheatsheet.rst:65
msgid ""
"``blockhash(uint blockNumber) returns (bytes32)``: hash of the given block - "
"only works for 256 most recent blocks"
msgstr ""

#: ../../../cheatsheet.rst:66
msgid ""
"``blobhash(uint index) returns (bytes32)``: versioned hash of the ``index``-"
"th blob associated with the current transaction. A versioned hash consists "
"of a single byte representing the version (currently ``0x01``), followed by "
"the last 31 bytes of the SHA256 hash of the KZG commitment (`EIP-4844 "
"<https://eips.ethereum.org/EIPS/eip-4844>`_). Returns zero if no blob with "
"the given index exists."
msgstr ""

#: ../../../cheatsheet.rst:70
msgid ""
"``block.basefee`` (``uint``): current block's base fee (`EIP-3198 <https://"
"eips.ethereum.org/EIPS/eip-3198>`_ and `EIP-1559 <https://eips.ethereum.org/"
"EIPS/eip-1559>`_)"
msgstr ""

#: ../../../cheatsheet.rst:71
msgid ""
"``block.blobbasefee`` (``uint``): current block's blob base fee (`EIP-7516 "
"<https://eips.ethereum.org/EIPS/eip-7516>`_ and `EIP-4844 <https://eips."
"ethereum.org/EIPS/eip-4844>`_)"
msgstr ""

#: ../../../cheatsheet.rst:72
msgid "``block.chainid`` (``uint``): current chain id"
msgstr ""

#: ../../../cheatsheet.rst:73
msgid "``block.coinbase`` (``address payable``): current block miner's address"
msgstr ""

#: ../../../cheatsheet.rst:74
msgid ""
"``block.difficulty`` (``uint``): current block difficulty (``EVM < Paris``). "
"For other EVM versions it behaves as a deprecated alias for ``block."
"prevrandao`` that will be removed in the next breaking release"
msgstr ""

#: ../../../cheatsheet.rst:75
msgid "``block.gaslimit`` (``uint``): current block gaslimit"
msgstr ""

#: ../../../cheatsheet.rst:76
msgid "``block.number`` (``uint``): current block number"
msgstr ""

#: ../../../cheatsheet.rst:77
msgid ""
"``block.prevrandao`` (``uint``): random number provided by the beacon chain "
"(``EVM >= Paris``) (see `EIP-4399 <https://eips.ethereum.org/EIPS/"
"eip-4399>`_ )"
msgstr ""

#: ../../../cheatsheet.rst:78
msgid ""
"``block.timestamp`` (``uint``): current block timestamp in seconds since "
"Unix epoch"
msgstr ""

#: ../../../cheatsheet.rst:79
msgid "``gasleft() returns (uint256)``: remaining gas"
msgstr ""

#: ../../../cheatsheet.rst:80
msgid "``msg.data`` (``bytes``): complete calldata"
msgstr ""

#: ../../../cheatsheet.rst:81
msgid "``msg.sender`` (``address``): sender of the message (current call)"
msgstr ""

#: ../../../cheatsheet.rst:82
msgid ""
"``msg.sig`` (``bytes4``): first four bytes of the calldata (i.e. function "
"identifier)"
msgstr ""

#: ../../../cheatsheet.rst:83
msgid "``msg.value`` (``uint``): number of wei sent with the message"
msgstr ""

#: ../../../cheatsheet.rst:84
msgid "``tx.gasprice`` (``uint``): gas price of the transaction"
msgstr ""

#: ../../../cheatsheet.rst:85
msgid ""
"``tx.origin`` (``address``): sender of the transaction (full call chain)"
msgstr ""

#: ../../../cheatsheet.rst:90
msgid "Validations and Assertions"
msgstr ""

#: ../../../cheatsheet.rst:92
msgid ""
"``assert(bool condition)``: abort execution and revert state changes if "
"condition is ``false`` (use for internal error)"
msgstr ""

#: ../../../cheatsheet.rst:93
msgid ""
"``require(bool condition)``: abort execution and revert state changes if "
"condition is ``false`` (use for malformed input or error in external "
"component)"
msgstr ""

#: ../../../cheatsheet.rst:95
msgid ""
"``require(bool condition, string memory message)``: abort execution and "
"revert state changes if condition is ``false`` (use for malformed input or "
"error in external component). Also provide error message."
msgstr ""

#: ../../../cheatsheet.rst:97
msgid "``revert()``: abort execution and revert state changes"
msgstr ""

#: ../../../cheatsheet.rst:98
msgid ""
"``revert(string memory message)``: abort execution and revert state changes "
"providing an explanatory string"
msgstr ""

#: ../../../cheatsheet.rst:103
msgid "Mathematical and Cryptographic Functions"
msgstr ""

#: ../../../cheatsheet.rst:105
msgid ""
"``keccak256(bytes memory) returns (bytes32)``: compute the Keccak-256 hash "
"of the input"
msgstr ""

#: ../../../cheatsheet.rst:106
msgid ""
"``sha256(bytes memory) returns (bytes32)``: compute the SHA-256 hash of the "
"input"
msgstr ""

#: ../../../cheatsheet.rst:107
msgid ""
"``ripemd160(bytes memory) returns (bytes20)``: compute the RIPEMD-160 hash "
"of the input"
msgstr ""

#: ../../../cheatsheet.rst:108
msgid ""
"``ecrecover(bytes32 hash, uint8 v, bytes32 r, bytes32 s) returns "
"(address)``: recover address associated with the public key from elliptic "
"curve signature, return zero on error"
msgstr ""

#: ../../../cheatsheet.rst:110
msgid ""
"``addmod(uint x, uint y, uint k) returns (uint)``: compute ``(x + y) % k`` "
"where the addition is performed with arbitrary precision and does not wrap "
"around at ``2**256``. Assert that ``k != 0`` starting from version 0.5.0."
msgstr ""

#: ../../../cheatsheet.rst:112
msgid ""
"``mulmod(uint x, uint y, uint k) returns (uint)``: compute ``(x * y) % k`` "
"where the multiplication is performed with arbitrary precision and does not "
"wrap around at ``2**256``. Assert that ``k != 0`` starting from version "
"0.5.0."
msgstr ""

#: ../../../cheatsheet.rst:118
msgid "Contract-related"
msgstr ""

#: ../../../cheatsheet.rst:120
msgid ""
"``this`` (current contract's type): the current contract, explicitly "
"convertible to ``address`` or ``address payable``"
msgstr ""

#: ../../../cheatsheet.rst:121
msgid "``super``: a contract one level higher in the inheritance hierarchy"
msgstr ""

#: ../../../cheatsheet.rst:122
msgid ""
"``selfdestruct(address payable recipient)``: send all funds to the given "
"address and (only on EVMs before Cancun or when invoked within the "
"transaction creating the contract) destroy the contract."
msgstr ""

#: ../../../cheatsheet.rst:127
msgid "Type Information"
msgstr ""

#: ../../../cheatsheet.rst:129
msgid "``type(C).name`` (``string``): the name of the contract"
msgstr ""

#: ../../../cheatsheet.rst:130
msgid ""
"``type(C).creationCode`` (``bytes memory``): creation bytecode of the given "
"contract, see :ref:`Type Information<meta-type>`."
msgstr ""

#: ../../../cheatsheet.rst:131
msgid ""
"``type(C).runtimeCode`` (``bytes memory``): runtime bytecode of the given "
"contract, see :ref:`Type Information<meta-type>`."
msgstr ""

#: ../../../cheatsheet.rst:132
msgid ""
"``type(I).interfaceId`` (``bytes4``): value containing the EIP-165 interface "
"identifier of the given interface, see :ref:`Type Information<meta-type>`."
msgstr ""

#: ../../../cheatsheet.rst:133
msgid ""
"``type(T).min`` (``T``): the minimum value representable by the integer type "
"``T``, see :ref:`Type Information<meta-type>`."
msgstr ""

#: ../../../cheatsheet.rst:134
msgid ""
"``type(T).max`` (``T``): the maximum value representable by the integer type "
"``T``, see :ref:`Type Information<meta-type>`."
msgstr ""

#: ../../../cheatsheet.rst:140
msgid "Function Visibility Specifiers"
msgstr ""

#: ../../../cheatsheet.rst:142
msgid ""
"function myFunction() <visibility specifier> returns (bool) {\n"
"    return true;\n"
"}"
msgstr ""

#: ../../../cheatsheet.rst:149
msgid ""
"``public``: visible externally and internally (creates a :ref:`getter "
"function<getter-functions>` for storage/state variables)"
msgstr ""

#: ../../../cheatsheet.rst:150
msgid "``private``: only visible in the current contract"
msgstr ""

#: ../../../cheatsheet.rst:151
msgid ""
"``external``: only visible externally (only for functions) - i.e. can only "
"be message-called (via ``this.func``)"
msgstr ""

#: ../../../cheatsheet.rst:152
msgid "``internal``: only visible internally"
msgstr ""

#: ../../../cheatsheet.rst:158
msgid "Modifiers"
msgstr ""

#: ../../../cheatsheet.rst:160
msgid "``pure`` for functions: Disallows modification or access of state."
msgstr ""

#: ../../../cheatsheet.rst:161
msgid "``view`` for functions: Disallows modification of state."
msgstr ""

#: ../../../cheatsheet.rst:162
msgid ""
"``payable`` for functions: Allows them to receive Ether together with a call."
msgstr ""

#: ../../../cheatsheet.rst:163
msgid ""
"``constant`` for state variables: Disallows assignment (except "
"initialization), does not occupy storage slot."
msgstr ""

#: ../../../cheatsheet.rst:164
msgid ""
"``immutable`` for state variables: Allows assignment at construction time "
"and is constant when deployed. Is stored in code."
msgstr ""

#: ../../../cheatsheet.rst:165
msgid "``anonymous`` for events: Does not store event signature as topic."
msgstr ""

#: ../../../cheatsheet.rst:166
msgid "``indexed`` for event parameters: Stores the parameter as topic."
msgstr ""

#: ../../../cheatsheet.rst:167
msgid ""
"``virtual`` for functions and modifiers: Allows the function's or modifier's "
"behavior to be changed in derived contracts."
msgstr ""

#: ../../../cheatsheet.rst:169
msgid ""
"``override``: States that this function, modifier or public state variable "
"changes the behavior of a function or modifier in a base contract."
msgstr ""

